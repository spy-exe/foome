{
  "expo": {
    "name": "Foome",
    "slug": "foome",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.foome.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Foome usa a câmera para sua foto de perfil.",
        "NSFaceIDUsageDescription": "Foome usa biometria para confirmar suas compras.",
        "NSLocationWhenInUseUsageDescription": "Foome usa sua localização para mostrar restaurantes próximos e acompanhar a entrega."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF2E4D"
      },
      "package": "com.foome.app",
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Foome precisa da câmera para sua foto de perfil."
        }
      ],
      "expo-splash-screen",
      "expo-font"
    ]
  }
}
